{
  "manifest_version": 3,
  "name": "Auto-Proposal AI (Sidebar Edition)",
  "description": "Sidebar inteligente para o 99freelas que filtra projetos e gera propostas usando o Gemini.",
  "version": "2.0",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "ap16.png",
      "48": "ap48.png",
      "128": "ap128.png"
    }
  },
  "icons": {
    "16": "ap16.png",
    "48": "ap48.png",
    "128": "ap128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.99freelas.com.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}