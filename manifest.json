{
  "manifest_version": 3,
  "name": "Minha Extensão",
  "description": "Uma extensão que coleta dados da página, faz uma requisição API e insere a resposta.",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "storage",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "run-extraction": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+X"
      },
      "description": "Executar extração e requisição"
    }
  }
}