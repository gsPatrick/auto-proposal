{
  "manifest_version": 3,
  "name": "Auto-Proposal",
  "description": "Uma extensão para o 99freelas que coleta as informações do projeto e do cliente, faz uma requisição API pro Gemini e insere a resposta.",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "storage",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "ap16.png",
      "48": "ap48.png",
      "128": "ap128.png"
    }
  },
  "icons": {
    "16": "ap16.png",
    "48": "ap48.png",
    "128": "ap128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "run-extraction": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+X"
      },
      "description": "Executar extração e requisição"
    }
  }
}
